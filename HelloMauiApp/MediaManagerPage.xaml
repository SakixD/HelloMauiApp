<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelloMauiApp.MediaManagerPage"
             Title="Druckmedium">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="Vom Drucker erkennen" FontAttributes="Bold" />
            <Label Text="Liest die zuletzt kalibrierte Etikettenlänge sowie Papier-/Farbband-/Kopfstatus aus. Die Breite kann der Drucker nicht melden und muss manuell eingetragen werden."
                   FontSize="12" TextColor="Gray" />
            <Button x:Name="DetectBtn" Text="Medium vom Drucker erkennen" Clicked="OnDetectClicked" />
            <Label x:Name="DetectResultLabel" FontSize="12" TextColor="Gray" IsVisible="False" />

            <BoxView HeightRequest="1" BackgroundColor="LightGray" Margin="0,8" />

            <Label Text="Gespeicherte Medien" FontAttributes="Bold" />
            <VerticalStackLayout x:Name="MediaListLayout" Spacing="8" />
            <Button Text="Neues Medium" Clicked="OnAddMediaClicked" />

            <Border x:Name="EditPanel" IsVisible="False" Padding="12" StrokeThickness="1" Stroke="LightGray">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Name" />
                    <Entry x:Name="NameEntry" />
                    <Label Text="Breite (mm)" />
                    <Entry x:Name="WidthEntry" Keyboard="Numeric" />
                    <Label Text="Höhe (mm)" />
                    <Entry x:Name="HeightEntry" Keyboard="Numeric" />
                    <Label Text="Gap (mm)" />
                    <Entry x:Name="GapEntry" Keyboard="Numeric" />
                    <Label Text="Sensor" />
                    <Picker x:Name="SensorPicker">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Lücke</x:String>
                                <x:String>Schwarzmarke</x:String>
                                <x:String>Endlos</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                    <Label Text="Material" />
                    <Entry x:Name="MaterialEntry" Placeholder="z.B. Thermodirekt, Thermotransfer-Papier..." />

                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Speichern" Clicked="OnSaveMediaClicked" />
                        <Button Text="Löschen" BackgroundColor="IndianRed" TextColor="White" Clicked="OnDeleteMediaClicked" />
                        <Button Text="Abbrechen" Clicked="OnCancelEditClicked" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
