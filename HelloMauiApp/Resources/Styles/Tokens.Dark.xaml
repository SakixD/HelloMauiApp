<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HelloMauiApp.Resources.Styles.TokensDark">

    <!-- Dunkeltheme-Gegenstück zu Tokens.Light.xaml (siehe dort für Erklärung des Mechanismus). -->

    <Color x:Key="ColorBg">#1E1E22</Color>
    <Color x:Key="ColorDesk">#0E0E12</Color>
    <Color x:Key="ColorTitlebar">#26262B</Color>
    <Color x:Key="ColorNav">#232328</Color>
    <Color x:Key="ColorLayer">#2A2A30</Color>
    <Color x:Key="ColorLayer2">#2F2F36</Color>
    <Color x:Key="ColorLayer3">#34343C</Color>

    <Color x:Key="ColorStroke">#14FFFFFF</Color>
    <Color x:Key="ColorText">#F2F2F5</Color>
    <Color x:Key="ColorText2">#A8A8B3</Color>
    <Color x:Key="ColorText3">#72727B</Color>

    <Color x:Key="ColorControl">#0DFFFFFF</Color>
    <Color x:Key="ColorControlHover">#1AFFFFFF</Color>
    <Color x:Key="ColorControlStroke">#1AFFFFFF</Color>

    <Color x:Key="ColorSuccess">#3BD6A4</Color>
    <Color x:Key="ColorDanger">#FF6B7A</Color>
    <Color x:Key="ColorDangerSoft">#24FF6B7A</Color>
    <Color x:Key="ColorDangerBorder">#59FF6B7A</Color>

    <Color x:Key="ColorCanvasBg">#151519</Color>
    <Color x:Key="ColorCanvasDot">#0DFFFFFF</Color>
    <Color x:Key="ColorCodeBg">#161619</Color>
    <Color x:Key="ColorCodeFg">#C6C6D0</Color>
    <Color x:Key="ColorToastBg">#2F2F37</Color>
    <Color x:Key="ColorToastFg">#F2F2F5</Color>

    <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#26232F" Offset="0.0" />
        <GradientStop Color="#201F26" Offset="1.0" />
    </LinearGradientBrush>

</ResourceDictionary>
