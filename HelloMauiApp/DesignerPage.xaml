<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelloMauiApp.DesignerPage"
             Title="Label-Designer">

    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

        <Label x:Name="TitleLabel"
               Grid.Row="0"
               Text="Label-Designer"
               FontSize="16"
               FontAttributes="Bold"
               Padding="12,10,12,4" />

        <ScrollView Grid.Row="1" Orientation="Horizontal">
            <HorizontalStackLayout Spacing="8" Padding="12,0,12,10">
                <Button Text="Neu" Clicked="OnNewClicked" />
                <Button Text="+ Text" Clicked="OnAddTextClicked" />
                <Button Text="+ Barcode" Clicked="OnAddBarcodeClicked" />
                <Button Text="+ Bild" Clicked="OnAddImageClicked" />
                <Button Text="+ Rahmen" Clicked="OnAddFrameClicked" />
                <Button Text="+ Linie" Clicked="OnAddLineClicked" />
                <Button Text="Platzhalter verwalten" Clicked="OnManagePlaceholdersClicked" />
                <Button Text="Vorlage laden" Clicked="OnLoadClicked" />
                <Button Text="Speichern" Clicked="OnSaveClicked" />
                <Button Text="Exportieren" Clicked="OnExportClicked" />
                <Button Text="Importieren" Clicked="OnImportClicked" />
                <Button Text="Drucken" Clicked="OnPrintClicked" />
            </HorizontalStackLayout>
        </ScrollView>

        <ScrollView Grid.Row="2" BackgroundColor="#DDDDDD">
            <Border Stroke="Gray"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Margin="24">
                <AbsoluteLayout x:Name="CanvasLayout" />
            </Border>
        </ScrollView>

        <Border x:Name="PropertiesPanel"
                Grid.Row="3"
                IsVisible="False"
                Padding="12"
                StrokeThickness="0,1,0,0"
                Stroke="LightGray"
                MaximumHeightRequest="420">
            <ScrollView>
                <VerticalStackLayout Spacing="8">

                    <Label x:Name="SelectedElementLabel" FontAttributes="Bold" />

                    <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                        <Label Text="X (mm)" Grid.Column="0" VerticalOptions="Center" />
                        <Entry x:Name="XEntry" Grid.Column="1" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                        <Label Text="Y (mm)" Grid.Column="2" VerticalOptions="Center" />
                        <Entry x:Name="YEntry" Grid.Column="3" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                    </Grid>

                    <VerticalStackLayout x:Name="TextPropertiesGroup" Spacing="4" IsVisible="False">
                        <Label Text="Text" />
                        <Entry x:Name="TextValueEntry" TextChanged="OnPropertyChanged" />
                        <HorizontalStackLayout Spacing="6">
                            <CheckBox x:Name="TextIsPlaceholderCheckBox" CheckedChanged="OnTextIsPlaceholderChanged" />
                            <Label Text="Als Platzhalter" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Picker x:Name="TextPlaceholderPicker" Title="Platzhalter wählen" IsVisible="False" SelectedIndexChanged="OnPropertyChanged" />
                        <Label Text="Schriftgröße (mm)" />
                        <Entry x:Name="FontSizeEntry" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="BarcodePropertiesGroup" Spacing="4" IsVisible="False">
                        <Label Text="Symbologie" />
                        <Picker x:Name="BarcodeSymbologyPicker" SelectedIndexChanged="OnBarcodeSymbologyChanged">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Code128</x:String>
                                    <x:String>EAN-13</x:String>
                                    <x:String>Code39</x:String>
                                    <x:String>QR-Code</x:String>
                                    <x:String>DataMatrix</x:String>
                                    <x:String>PDF417</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>

                        <Label Text="Daten" />
                        <Entry x:Name="BarcodeDataEntry" TextChanged="OnPropertyChanged" />
                        <HorizontalStackLayout Spacing="6">
                            <CheckBox x:Name="BarcodeIsPlaceholderCheckBox" CheckedChanged="OnBarcodeIsPlaceholderChanged" />
                            <Label Text="Als Platzhalter" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Picker x:Name="BarcodePlaceholderPicker" Title="Platzhalter wählen" IsVisible="False" SelectedIndexChanged="OnPropertyChanged" />

                        <VerticalStackLayout x:Name="Barcode1DPropertiesGroup" Spacing="4">
                            <Label Text="Höhe (mm)" />
                            <Entry x:Name="BarcodeHeightEntry" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                            <HorizontalStackLayout Spacing="6">
                                <CheckBox x:Name="BarcodeHrCheckBox" CheckedChanged="OnPropertyChanged" />
                                <Label Text="Daten als Text mit anzeigen" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="Barcode2DPropertiesGroup" Spacing="4">
                            <Label Text="Modulgröße" />
                            <Entry x:Name="BarcodeMagnificationEntry" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="BarcodeQrEcGroup" Spacing="4">
                            <Label Text="Fehlerkorrektur (QR)" />
                            <Picker x:Name="QrErrorCorrectionPicker" SelectedIndexChanged="OnPropertyChanged">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Niedrig (~7%)</x:String>
                                        <x:String>Mittel (~15%)</x:String>
                                        <x:String>Qualität (~25%)</x:String>
                                        <x:String>Hoch (~30%)</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="ImagePropertiesGroup" Spacing="4" IsVisible="False">
                        <Label Text="Breite (mm)" />
                        <Entry x:Name="ImageWidthEntry" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                        <Label Text="Höhe (mm)" />
                        <Entry x:Name="ImageHeightEntry" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="FramePropertiesGroup" Spacing="4" IsVisible="False">
                        <Label Text="Breite (mm)" />
                        <Entry x:Name="FrameWidthEntry" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                        <Label Text="Länge/Höhe (mm)" />
                        <Entry x:Name="FrameHeightEntry" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                        <Label Text="Dicke (mm)" />
                        <Entry x:Name="FrameThicknessEntry" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                        <HorizontalStackLayout Spacing="6">
                            <CheckBox x:Name="FrameFilledCheckBox" CheckedChanged="OnPropertyChanged" />
                            <Label Text="Gefüllt" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="LinePropertiesGroup" Spacing="4" IsVisible="False">
                        <Label Text="Länge (mm)" />
                        <Entry x:Name="LineLengthEntry" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                        <Label Text="Dicke (mm)" />
                        <Entry x:Name="LineThicknessEntry" Keyboard="Numeric" TextChanged="OnPropertyChanged" />
                        <Label Text="Ausrichtung" />
                        <Label Text="ZPL-Drucker können Linien nur horizontal oder vertikal drucken, kein freier Winkel."
                               FontSize="11" TextColor="Gray" />
                        <Picker x:Name="LineOrientationPicker" SelectedIndexChanged="OnPropertyChanged">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Horizontal</x:String>
                                    <x:String>Vertikal</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </VerticalStackLayout>

                    <Button Text="Element löschen" BackgroundColor="IndianRed" TextColor="White" Clicked="OnDeleteElementClicked" />

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>

</ContentPage>
