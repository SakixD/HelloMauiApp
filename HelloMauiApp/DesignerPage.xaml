<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:HelloMauiApp.ViewModels"
             x:Class="HelloMauiApp.DesignerPage"
             x:DataType="viewmodels:DesignerViewModel">

    <!-- Card/ChipButton/... kommen zentral aus Resources/Styles/Styles.xaml -->

    <Grid RowDefinitions="Auto,Auto,*" Padding="24,20,24,20" RowSpacing="14">

        <!-- KOPFZEILE: Titel + Vorlagen-Aktionen -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Label-Designer" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                <Label Text="{Binding Title}" FontSize="12.5" TextColor="{DynamicResource ColorText2}" />
            </VerticalStackLayout>
            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                <Button Text="Neu" Style="{DynamicResource ChipButton}" Command="{Binding NewCommand}" />
                <Button Text="Laden" Style="{DynamicResource ChipButton}" Command="{Binding LoadCommand}" />
                <Button Text="Importieren" Style="{DynamicResource ChipButton}" Command="{Binding ImportCommand}" />
                <Button Text="Exportieren" Style="{DynamicResource ChipButton}" Command="{Binding ExportCommand}" />
                <Button Text="Speichern" Style="{DynamicResource ChipButton}" Command="{Binding SaveCommand}" />
                <Button Text="Drucken" Style="{DynamicResource AccentChipButton}" Command="{Binding PrintCommand}" />
            </HorizontalStackLayout>
        </Grid>

        <!-- WERKZEUGLEISTE: Elemente + Vorlagen-Kontext -->
        <Border Grid.Row="1" Style="{DynamicResource Card}" Padding="12,9">
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="EINFÜGEN" FontSize="11" CharacterSpacing="0.5" TextColor="{DynamicResource ColorText3}" VerticalOptions="Center" Margin="2,0,4,0" />
                    <Button Text="+ Text" Style="{DynamicResource ChipButton}" Command="{Binding AddTextCommand}" />
                    <Button Text="+ Barcode" Style="{DynamicResource ChipButton}" Command="{Binding AddBarcodeCommand}" />
                    <Button Text="+ Bild" Style="{DynamicResource ChipButton}" Command="{Binding AddImageCommand}" />
                    <Button Text="+ Rahmen" Style="{DynamicResource ChipButton}" Command="{Binding AddFrameCommand}" />
                    <Button Text="+ Ellipse" Style="{DynamicResource ChipButton}" Command="{Binding AddEllipseCommand}" />
                    <Button Text="+ Linie" Style="{DynamicResource ChipButton}" Command="{Binding AddLineCommand}" />
                    <BoxView Style="{DynamicResource ToolbarSeparator}" />
                    <Label Text="VORLAGE" FontSize="11" CharacterSpacing="0.5" TextColor="{DynamicResource ColorText3}" VerticalOptions="Center" Margin="2,0,4,0" />
                    <Button Text="Medium" Style="{DynamicResource ChipButton}" Command="{Binding ManageMediaCommand}" />
                    <Button Text="Platzhalter" Style="{DynamicResource ChipButton}" Command="{Binding ManagePlaceholdersCommand}" />
                    <Button Text="Eigenschaften" Style="{DynamicResource ChipButton}" Command="{Binding EditPropertiesCommand}" />
                </HorizontalStackLayout>
            </ScrollView>
        </Border>

        <!-- ARBEITSBEREICH: Canvas links, Eigenschaften + ZPL rechts -->
        <Grid Grid.Row="2" ColumnDefinitions="*,330" ColumnSpacing="16">

            <Border Grid.Column="0" Style="{DynamicResource Card}" BackgroundColor="{DynamicResource ColorCanvasBg}" Padding="0">
                <Grid>
                    <ScrollView Orientation="Both">
                        <Border x:Name="LabelSurface"
                                BackgroundColor="White"
                                Stroke="#33000000"
                                StrokeThickness="1"
                                Margin="32"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                            <AbsoluteLayout x:Name="CanvasLayout" />
                        </Border>
                    </ScrollView>

                    <!-- Zoom-Steuerung (Overlay unten rechts) -->
                    <Border Style="{DynamicResource Card}" HorizontalOptions="End" VerticalOptions="End" Margin="14" Padding="4,2">
                        <HorizontalStackLayout Spacing="0">
                            <Button Text="−" Style="{DynamicResource ChipButton}" WidthRequest="34" Padding="0" Clicked="OnZoomOutClicked" />
                            <Label x:Name="ZoomLabel" Text="100 %" FontSize="12.5" TextColor="{DynamicResource ColorText2}"
                                   WidthRequest="52" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                            <Button Text="+" Style="{DynamicResource ChipButton}" WidthRequest="34" Padding="0" Clicked="OnZoomInClicked" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>
            </Border>

            <ScrollView Grid.Column="1">
                <VerticalStackLayout Spacing="14">

                    <!-- EIGENSCHAFTEN -->
                    <Border Style="{DynamicResource Card}" Padding="18,16">
                        <VerticalStackLayout Spacing="0">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Eigenschaften" Style="{DynamicResource SectionTitle}" />
                                <Label Grid.Column="1" Text="{Binding SelectedElementTitle}" FontSize="12.5" FontAttributes="Bold"
                                       TextColor="{DynamicResource AccentColor}" VerticalOptions="Center" />
                            </Grid>

                            <Label IsVisible="{Binding HasNoSelection}"
                                   Text="Kein Element ausgewählt. Tippe ein Element auf der Arbeitsfläche an oder füge oben ein neues ein."
                                   FontSize="12.5" TextColor="{DynamicResource ColorText2}" Margin="0,10,0,0" />

                            <VerticalStackLayout IsVisible="{Binding HasSelection}" Spacing="0">

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <VerticalStackLayout Grid.Column="0" Spacing="0">
                                        <Label Text="X (MM)" Style="{DynamicResource FieldLabel}" />
                                        <Entry Text="{Binding XText}" Keyboard="Numeric" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="0">
                                        <Label Text="Y (MM)" Style="{DynamicResource FieldLabel}" />
                                        <Entry Text="{Binding YText}" Keyboard="Numeric" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Text -->
                                <VerticalStackLayout IsVisible="{Binding IsTextSelected}" Spacing="0">
                                    <Label Text="TEXT" Style="{DynamicResource FieldLabel}" />
                                    <Entry Text="{Binding TextValue}" IsVisible="{Binding TextLiteralVisible}" />
                                    <Picker ItemsSource="{Binding PlaceholderKeys}" SelectedItem="{Binding TextPlaceholderKey}"
                                            Title="Platzhalter wählen" IsVisible="{Binding TextIsPlaceholder}" />
                                    <HorizontalStackLayout Spacing="2">
                                        <CheckBox IsChecked="{Binding TextIsPlaceholder}" />
                                        <Label Text="Als Platzhalter" FontSize="13" TextColor="{DynamicResource ColorText2}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="SCHRIFTGRÖSSE (MM)" Style="{DynamicResource FieldLabel}" />
                                    <Entry Text="{Binding FontSizeText}" Keyboard="Numeric" />
                                    <Label Text="DREHUNG" Style="{DynamicResource FieldLabel}" />
                                    <Picker SelectedIndex="{Binding TextRotationIndex}">
                                        <Picker.ItemsSource>
                                            <x:Array Type="{x:Type x:String}">
                                                <x:String>0° (normal)</x:String>
                                                <x:String>90° (im Uhrzeigersinn)</x:String>
                                                <x:String>180° (kopfüber)</x:String>
                                                <x:String>270° (von unten nach oben)</x:String>
                                            </x:Array>
                                        </Picker.ItemsSource>
                                    </Picker>
                                </VerticalStackLayout>

                                <!-- Barcode -->
                                <VerticalStackLayout IsVisible="{Binding IsBarcodeSelected}" Spacing="0">
                                    <Label Text="SYMBOLOGIE" Style="{DynamicResource FieldLabel}" />
                                    <Picker SelectedIndex="{Binding SymbologyIndex}">
                                        <Picker.ItemsSource>
                                            <x:Array Type="{x:Type x:String}">
                                                <x:String>Code128</x:String>
                                                <x:String>EAN-13</x:String>
                                                <x:String>Code39</x:String>
                                                <x:String>QR-Code</x:String>
                                                <x:String>DataMatrix</x:String>
                                                <x:String>PDF417</x:String>
                                            </x:Array>
                                        </Picker.ItemsSource>
                                    </Picker>
                                    <Label Text="DATEN" Style="{DynamicResource FieldLabel}" />
                                    <Entry Text="{Binding BarcodeData}" IsVisible="{Binding BarcodeLiteralVisible}" />
                                    <Picker ItemsSource="{Binding PlaceholderKeys}" SelectedItem="{Binding BarcodePlaceholderKey}"
                                            Title="Platzhalter wählen" IsVisible="{Binding BarcodeIsPlaceholder}" />
                                    <HorizontalStackLayout Spacing="2">
                                        <CheckBox IsChecked="{Binding BarcodeIsPlaceholder}" />
                                        <Label Text="Als Platzhalter" FontSize="13" TextColor="{DynamicResource ColorText2}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <VerticalStackLayout IsVisible="{Binding IsBarcode1DVisible}" Spacing="0">
                                        <Label Text="HÖHE (MM)" Style="{DynamicResource FieldLabel}" />
                                        <Entry Text="{Binding BarcodeHeightText}" Keyboard="Numeric" />
                                        <HorizontalStackLayout Spacing="2">
                                            <CheckBox IsChecked="{Binding BarcodeHumanReadable}" />
                                            <Label Text="Daten als Text mit anzeigen" FontSize="13" TextColor="{DynamicResource ColorText2}" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout IsVisible="{Binding IsBarcode2DVisible}" Spacing="0">
                                        <Label Text="MODULGRÖSSE" Style="{DynamicResource FieldLabel}" />
                                        <Entry Text="{Binding BarcodeMagnificationText}" Keyboard="Numeric" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout IsVisible="{Binding IsQrVisible}" Spacing="0">
                                        <Label Text="FEHLERKORREKTUR (QR)" Style="{DynamicResource FieldLabel}" />
                                        <Picker SelectedIndex="{Binding QrErrorCorrectionIndex}">
                                            <Picker.ItemsSource>
                                                <x:Array Type="{x:Type x:String}">
                                                    <x:String>Niedrig (~7%)</x:String>
                                                    <x:String>Mittel (~15%)</x:String>
                                                    <x:String>Qualität (~25%)</x:String>
                                                    <x:String>Hoch (~30%)</x:String>
                                                </x:Array>
                                            </Picker.ItemsSource>
                                        </Picker>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>

                                <!-- Bild -->
                                <VerticalStackLayout IsVisible="{Binding IsImageSelected}" Spacing="0">
                                    <Label Text="BREITE (MM)" Style="{DynamicResource FieldLabel}" />
                                    <Entry Text="{Binding ImageWidthText}" Keyboard="Numeric" />
                                    <Label Text="HÖHE (MM)" Style="{DynamicResource FieldLabel}" />
                                    <Entry Text="{Binding ImageHeightText}" Keyboard="Numeric" />
                                </VerticalStackLayout>

                                <!-- Rahmen -->
                                <VerticalStackLayout IsVisible="{Binding IsFrameSelected}" Spacing="0">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <VerticalStackLayout Grid.Column="0" Spacing="0">
                                            <Label Text="BREITE (MM)" Style="{DynamicResource FieldLabel}" />
                                            <Entry Text="{Binding FrameWidthText}" Keyboard="Numeric" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                                            <Label Text="HÖHE (MM)" Style="{DynamicResource FieldLabel}" />
                                            <Entry Text="{Binding FrameHeightText}" Keyboard="Numeric" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Label Text="DICKE (MM)" Style="{DynamicResource FieldLabel}" />
                                    <Entry Text="{Binding FrameThicknessText}" Keyboard="Numeric" />
                                    <HorizontalStackLayout Spacing="2">
                                        <CheckBox IsChecked="{Binding FrameFilled}" />
                                        <Label Text="Gefüllt" FontSize="13" TextColor="{DynamicResource ColorText2}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Ellipse -->
                                <VerticalStackLayout IsVisible="{Binding IsEllipseSelected}" Spacing="0">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                        <VerticalStackLayout Grid.Column="0" Spacing="0">
                                            <Label Text="BREITE (MM)" Style="{DynamicResource FieldLabel}" />
                                            <Entry Text="{Binding EllipseWidthText}" Keyboard="Numeric" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                                            <Label Text="HÖHE (MM)" Style="{DynamicResource FieldLabel}" />
                                            <Entry Text="{Binding EllipseHeightText}" Keyboard="Numeric" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Label Text="RANDDICKE (MM)" Style="{DynamicResource FieldLabel}" />
                                    <Entry Text="{Binding EllipseThicknessText}" Keyboard="Numeric" />
                                    <HorizontalStackLayout Spacing="2">
                                        <CheckBox IsChecked="{Binding EllipseFilled}" />
                                        <Label Text="Gefüllt" FontSize="13" TextColor="{DynamicResource ColorText2}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Linie -->
                                <VerticalStackLayout IsVisible="{Binding IsLineSelected}" Spacing="0">
                                    <Label Text="LÄNGE (MM)" Style="{DynamicResource FieldLabel}" />
                                    <Entry Text="{Binding LineLengthText}" Keyboard="Numeric" />
                                    <Label Text="DICKE (MM)" Style="{DynamicResource FieldLabel}" />
                                    <Entry Text="{Binding LineThicknessText}" Keyboard="Numeric" />
                                    <Label Text="AUSRICHTUNG" Style="{DynamicResource FieldLabel}" />
                                    <Picker SelectedIndex="{Binding LineOrientationIndex}">
                                        <Picker.ItemsSource>
                                            <x:Array Type="{x:Type x:String}">
                                                <x:String>Horizontal</x:String>
                                                <x:String>Vertikal</x:String>
                                            </x:Array>
                                        </Picker.ItemsSource>
                                    </Picker>
                                    <Label Text="ZPL-Drucker drucken Linien nur horizontal oder vertikal, kein freier Winkel."
                                           FontSize="11" TextColor="{DynamicResource ColorText3}" Margin="0,4,0,0" />
                                </VerticalStackLayout>

                                <Button Text="Element löschen" Style="{DynamicResource DangerButton}" Command="{Binding DeleteElementCommand}" Margin="0,16,0,0" />

                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ZPL-VORSCHAU -->
                    <Border Style="{DynamicResource Card}" Padding="18,16">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="ZPL-Vorschau" Style="{DynamicResource SectionTitle}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="Kopieren" Style="{DynamicResource ChipButton}" Command="{Binding CopyZplCommand}" />
                            </Grid>
                            <Border BackgroundColor="{DynamicResource ColorCodeBg}" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="12,10">
                                <Label Text="{Binding ZplPreview}" FontFamily="Consolas" FontSize="11.5"
                                       TextColor="{DynamicResource ColorCodeFg}" LineBreakMode="CharacterWrap" />
                            </Border>
                            <Label Text="Aktualisiert sich beim Bearbeiten automatisch. „Kopieren“ übernimmt den vollständigen Code (inkl. Bilddaten)."
                                   FontSize="11.5" TextColor="{DynamicResource ColorText3}" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>

</ContentView>
