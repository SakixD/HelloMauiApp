<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelloMauiApp.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="32,28" Spacing="24" MaximumWidthRequest="1080" HorizontalOptions="Center">

            <!-- HERO -->
            <Border StrokeThickness="1" Stroke="{DynamicResource ColorStroke}" Background="{DynamicResource HeroBackgroundBrush}"
                    StrokeShape="RoundRectangle 14" Padding="34,30">
                <VerticalStackLayout Spacing="4">
                    <Label Text="LABEL PRINTING SDK · TESTKONSOLE" FontSize="12" FontAttributes="Bold"
                           TextColor="{DynamicResource AccentColor}" CharacterSpacing="1.2" />
                    <Label Text="Etiketten entwerfen, testen &amp; drucken." FontSize="30" FontAttributes="Bold"
                           TextColor="{DynamicResource ColorText}" Margin="0,6,0,0" />
                    <Label Text="Alle SDK-Funktionen an einem Ort — vom visuellen Label-Designer über Platzhalter und Vorlagen bis zur direkten ZPL-Kommunikation mit deinem Drucker."
                           FontSize="14" TextColor="{DynamicResource ColorText2}" Margin="0,8,0,0" MaximumWidthRequest="520" />
                    <HorizontalStackLayout Spacing="12" Margin="0,18,0,0">
                        <Button Text="Neues Label entwerfen" Clicked="OnOpenDesignerClicked"
                                BackgroundColor="{DynamicResource AccentColor}" TextColor="{DynamicResource AccentTextColor}"
                                FontAttributes="Bold" CornerRadius="6" Padding="20,0" HeightRequest="40" />
                        <Button Text="ZPL-Konsole öffnen" Clicked="OnOpenZplConsoleClicked"
                                BackgroundColor="{DynamicResource ColorControl}" TextColor="{DynamicResource ColorText}"
                                CornerRadius="6" Padding="18,0" HeightRequest="40" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- STATUS + LIBRARY -->
            <Grid ColumnDefinitions="1.4*,1*" ColumnSpacing="20">

                <Border Grid.Column="0" StrokeThickness="1" Stroke="{DynamicResource ColorStroke}" BackgroundColor="{DynamicResource ColorLayer}"
                        StrokeShape="RoundRectangle 12" Padding="24,22">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Druckerstatus" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Ellipse x:Name="StatusDot" WidthRequest="8" HeightRequest="8" Fill="{DynamicResource ColorText3}" />
                                <Label x:Name="StatusLabel" Text="Nicht getestet" FontSize="12.5" FontAttributes="Bold" TextColor="{DynamicResource ColorText3}" />
                            </HorizontalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="14" ColumnSpacing="24">
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                                <Label Text="VERBINDUNG" FontSize="11" TextColor="{DynamicResource ColorText3}" CharacterSpacing="0.5" />
                                <Label x:Name="IpValueLabel" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                                <Label Text="AUFLÖSUNG" FontSize="11" TextColor="{DynamicResource ColorText3}" CharacterSpacing="0.5" />
                                <Label x:Name="DpiValueLabel" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                                <Label Text="LABELGRÖSSE" FontSize="11" TextColor="{DynamicResource ColorText3}" CharacterSpacing="0.5" />
                                <Label x:Name="MediaValueLabel" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                                <Label Text="ZULETZT KALIBRIERT" FontSize="11" TextColor="{DynamicResource ColorText3}" CharacterSpacing="0.5" />
                                <Label x:Name="CalibratedValueLabel" Text="—" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                            </VerticalStackLayout>
                        </Grid>

                        <HorizontalStackLayout Spacing="10">
                            <Button x:Name="TestConnectionBtn" Text="Verbindung testen" Clicked="OnTestConnectionClicked"
                                    BackgroundColor="{DynamicResource ColorControl}" TextColor="{DynamicResource ColorText}"
                                    FontSize="13" HeightRequest="34" Padding="14,0" />
                            <Button x:Name="CalibrateBtn" Text="Kalibrieren (~JC)" Clicked="OnCalibrateClicked"
                                    BackgroundColor="{DynamicResource ColorControl}" TextColor="{DynamicResource ColorText}"
                                    FontSize="13" HeightRequest="34" Padding="14,0" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" StrokeThickness="1" Stroke="{DynamicResource ColorStroke}" BackgroundColor="{DynamicResource ColorLayer}"
                        StrokeShape="RoundRectangle 12" Padding="24,22">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Bibliothek" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                        <HorizontalStackLayout Spacing="26" Margin="0,4,0,0">
                            <VerticalStackLayout>
                                <Label x:Name="TemplateCountLabel" Text="0" FontSize="28" FontAttributes="Bold" TextColor="{DynamicResource AccentColor}" />
                                <Label Text="Vorlagen" FontSize="12" TextColor="{DynamicResource ColorText2}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout>
                                <Label x:Name="MediaCountLabel" Text="0" FontSize="28" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                                <Label Text="Medien" FontSize="12" TextColor="{DynamicResource ColorText2}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout>
                                <Label x:Name="PlaceholderCountLabel" Text="0" FontSize="28" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                                <Label Text="Platzhalter" FontSize="12" TextColor="{DynamicResource ColorText2}" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <Button Text="Alle Vorlagen ansehen" Clicked="OnOpenTemplatesClicked" Margin="0,10,0,0"
                                BackgroundColor="{DynamicResource ColorControl}" TextColor="{DynamicResource ColorText}"
                                FontSize="13" HeightRequest="34" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- QUICK ACTIONS -->
            <VerticalStackLayout Spacing="14">
                <Label Text="Schnellzugriff" FontSize="15" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" Direction="Row">

                    <Border StrokeThickness="1" Stroke="{DynamicResource ColorStroke}" BackgroundColor="{DynamicResource ColorLayer}"
                            StrokeShape="RoundRectangle 10" Padding="18" WidthRequest="230" Margin="0,0,14,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDesignerTileTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <BoxView WidthRequest="38" HeightRequest="38" CornerRadius="9" BackgroundColor="{DynamicResource AccentSoftColor}" />
                            <Label Text="Label-Designer" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" Margin="0,10,0,0" />
                            <Label Text="Elemente per Drag &amp; Drop" FontSize="12" TextColor="{DynamicResource ColorText2}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border StrokeThickness="1" Stroke="{DynamicResource ColorStroke}" BackgroundColor="{DynamicResource ColorLayer}"
                            StrokeShape="RoundRectangle 10" Padding="18" WidthRequest="230" Margin="0,0,14,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTemplateTestTileTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <BoxView WidthRequest="38" HeightRequest="38" CornerRadius="9" BackgroundColor="{DynamicResource AccentSoftColor}" />
                            <Label Text="Vorlage testen" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" Margin="0,10,0,0" />
                            <Label Text="Platzhalter befüllen &amp; drucken" FontSize="12" TextColor="{DynamicResource ColorText2}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border StrokeThickness="1" Stroke="{DynamicResource ColorStroke}" BackgroundColor="{DynamicResource ColorLayer}"
                            StrokeShape="RoundRectangle 10" Padding="18" WidthRequest="230" Margin="0,0,14,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMediaTileTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <BoxView WidthRequest="38" HeightRequest="38" CornerRadius="9" BackgroundColor="{DynamicResource AccentSoftColor}" />
                            <Label Text="Medien" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" Margin="0,10,0,0" />
                            <Label Text="Rollen &amp; Sensortypen" FontSize="12" TextColor="{DynamicResource ColorText2}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border StrokeThickness="1" Stroke="{DynamicResource ColorStroke}" BackgroundColor="{DynamicResource ColorLayer}"
                            StrokeShape="RoundRectangle 10" Padding="18" WidthRequest="230" Margin="0,0,14,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPickImageTileTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <BoxView WidthRequest="38" HeightRequest="38" CornerRadius="9" BackgroundColor="{DynamicResource AccentSoftColor}" />
                            <Label Text="Bild drucken" FontSize="14" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" Margin="0,10,0,0" />
                            <Label Text="Logo/Symbol als Label" FontSize="12" TextColor="{DynamicResource ColorText2}" />
                        </VerticalStackLayout>
                    </Border>

                </FlexLayout>
            </VerticalStackLayout>

            <ActivityIndicator x:Name="BusyIndicator" IsRunning="False" IsVisible="False" />

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
