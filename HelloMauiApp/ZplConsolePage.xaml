<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelloMauiApp.ZplConsolePage"
             BackgroundColor="{DynamicResource ColorBg}">

    <!-- Card/ChipButton/FieldLabel kommen zentral aus Resources/Styles/Styles.xaml -->

    <Grid RowDefinitions="Auto,*" Padding="24,20" RowSpacing="14">

        <!-- KOPFZEILE -->
        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="ZPL-Konsole" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
            <Label Text="Rohes ZPL senden oder direkt mit dem Drucker sprechen (~HS, ~JC, getvar)"
                   FontSize="12.5" TextColor="{DynamicResource ColorText2}" />
        </VerticalStackLayout>

        <!-- INHALT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" MaximumWidthRequest="860" HorizontalOptions="Fill">

                <Border Style="{DynamicResource Card}" Padding="18,16">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Eingabe" Style="{DynamicResource SectionTitle}" />

                        <Label Text="ZPL / BEFEHL" Style="{DynamicResource FieldLabel}" />
                        <Editor x:Name="ZplEditor"
                                Placeholder="^XA ... ^XZ  oder ein Befehl wie ~HS / ! U1 getvar &quot;media.type&quot;"
                                AutoSize="TextChanges" MinimumHeightRequest="110"
                                TextColor="{DynamicResource ColorCodeFg}" BackgroundColor="{DynamicResource ColorCodeBg}" />

                        <HorizontalStackLayout Spacing="8" Margin="0,14,0,0">
                            <Button x:Name="SendZplBtn" Text="ZPL senden" Style="{DynamicResource AccentChipButton}" Clicked="OnSendZplClicked" />
                            <Button x:Name="SendZplQueryBtn" Text="Senden &amp; Antwort lesen" Style="{DynamicResource ChipButton}" Clicked="OnSendZplQueryClicked" />
                            <BoxView Style="{DynamicResource ToolbarSeparator}" />
                            <Button x:Name="QueryStatusBtn" Text="Status abfragen (~HS)" Style="{DynamicResource ChipButton}" Clicked="OnQueryStatusClicked" />
                            <Button x:Name="PrintTestLabelBtn" Text="Testlabel drucken" Style="{DynamicResource ChipButton}" Clicked="OnPrintTestLabelClicked" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{DynamicResource Card}" Padding="18,16">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Antwort des Druckers" Style="{DynamicResource SectionTitle}" />
                        <Editor x:Name="ResponseEditor" IsReadOnly="True"
                                Placeholder="Antwort des Druckers erscheint hier..."
                                AutoSize="TextChanges" MinimumHeightRequest="90" Margin="0,10,0,0"
                                TextColor="{DynamicResource ColorSuccess}" BackgroundColor="{DynamicResource ColorCodeBg}" />
                    </VerticalStackLayout>
                </Border>

                <ActivityIndicator x:Name="BusyIndicator" IsRunning="False" IsVisible="False" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentView>
