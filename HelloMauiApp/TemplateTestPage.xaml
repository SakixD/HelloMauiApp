<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelloMauiApp.TemplateTestPage"
             Title="Vorlage testen"
             BackgroundColor="{DynamicResource ColorBg}">

    <!-- Card/ChipButton/FieldLabel kommen zentral aus Resources/Styles/Styles.xaml -->

    <Grid RowDefinitions="Auto,*" Padding="24,20" RowSpacing="14">

        <!-- KOPFZEILE -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Vorlage testen" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                <Label x:Name="TitleLabel" Text="Vorlage wählen, Testdaten eingeben, Vorschau oder Testdruck"
                       FontSize="12.5" TextColor="{DynamicResource ColorText2}" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="Andere Vorlage wählen" Style="{DynamicResource ChipButton}"
                    Clicked="OnChooseTemplateClicked" VerticalOptions="Center" />
        </Grid>

        <!-- INHALT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" MaximumWidthRequest="860" HorizontalOptions="Fill">

                <Border Style="{DynamicResource Card}" Padding="18,16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Testdaten" Style="{DynamicResource SectionTitle}" />
                        <Label Text="* = Pflichtfeld" FontSize="11" TextColor="{DynamicResource ColorText3}" />
                        <VerticalStackLayout x:Name="FormLayout" Spacing="10" Margin="0,4,0,0" />

                        <Label x:Name="ValidationErrorLabel" TextColor="{DynamicResource ColorDanger}" FontSize="12.5" IsVisible="False" />

                        <HorizontalStackLayout Spacing="8" Margin="0,10,0,0">
                            <Button Text="Vorschau (materialfrei)" Style="{DynamicResource ChipButton}" Clicked="OnPreviewClicked" />
                            <Button Text="Testdruck (echter Ausdruck)" Style="{DynamicResource AccentChipButton}" Clicked="OnTestPrintClicked" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{DynamicResource Card}" Padding="18,16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Vorschau" Style="{DynamicResource SectionTitle}" />
                        <ScrollView Orientation="Horizontal">
                            <!-- Weiß bleibt bewusst hart: die Fläche stellt das physische (weiße) Etikett dar. -->
                            <Border Stroke="{DynamicResource ColorStroke}"
                                    StrokeThickness="1"
                                    BackgroundColor="White"
                                    HorizontalOptions="Start">
                                <AbsoluteLayout x:Name="PreviewCanvas" />
                            </Border>
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
