<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelloMauiApp.PrinterSettingsPage"
             Title="Drucker-Einstellungen">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="10">

            <Label Text="IP-Adresse" FontAttributes="Bold" />
            <Entry x:Name="IpEntry" Placeholder="z.B. 192.168.1.50" />

            <Label Text="Port" FontAttributes="Bold" />
            <Entry x:Name="PortEntry" Placeholder="9100" Keyboard="Numeric" />

            <Label Text="Labelbreite (mm)" FontAttributes="Bold" />
            <Entry x:Name="WidthEntry" Placeholder="100" Keyboard="Numeric" />

            <Label Text="Labelhöhe (mm)" FontAttributes="Bold" />
            <Entry x:Name="HeightEntry" Placeholder="150" Keyboard="Numeric" />

            <Label Text="Auflösung (DPI)" FontAttributes="Bold" />
            <Entry x:Name="DpiEntry" Placeholder="203" Keyboard="Numeric" />
            <Label Text="Üblich: 203 dpi (8 Dots/mm) oder 300 dpi (12 Dots/mm) – siehe Typenschild des Druckers."
                   FontSize="12" TextColor="Gray" />

            <Button x:Name="SaveBtn" Text="Speichern" Clicked="OnSaveClicked" Margin="0,14,0,0" />
            <Button x:Name="TestBtn" Text="Verbindung testen" Clicked="OnTestClicked" />

            <ActivityIndicator x:Name="BusyIndicator" IsRunning="False" IsVisible="False" />
            <Label x:Name="StatusLabel" FontSize="13" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
