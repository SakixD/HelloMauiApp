<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelloMauiApp.TemplatePropertiesPage"
             Title="Vorlagen-Eigenschaften"
             BackgroundColor="{DynamicResource ColorBg}">

    <!-- Card/ChipButton/FieldLabel kommen zentral aus Resources/Styles/Styles.xaml -->

    <Grid RowDefinitions="Auto,*" Padding="24,20" RowSpacing="14">

        <!-- KOPFZEILE -->
        <VerticalStackLayout Grid.Row="0" Spacing="2">
            <Label Text="Vorlagen-Eigenschaften" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
            <Label Text="Metadaten und Druckparameter dieser Vorlage" FontSize="12.5" TextColor="{DynamicResource ColorText2}" />
        </VerticalStackLayout>

        <!-- INHALT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" MaximumWidthRequest="860" HorizontalOptions="Fill">

                <Border Style="{StaticResource Card}" Padding="18,16">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Metadaten" Style="{StaticResource SectionTitle}" />

                        <Label Text="ID" Style="{StaticResource FieldLabel}" />
                        <Label x:Name="IdLabel" FontSize="12" TextColor="{DynamicResource ColorText2}" />

                        <Label Text="BESCHREIBUNG" Style="{StaticResource FieldLabel}" />
                        <Editor x:Name="DescriptionEditor" AutoSize="TextChanges" MinimumHeightRequest="60" />

                        <Label Text="KATEGORIE" Style="{StaticResource FieldLabel}" />
                        <Entry x:Name="CategoryEntry" />

                        <Label Text="TAGS (KOMMAGETRENNT)" Style="{StaticResource FieldLabel}" />
                        <Entry x:Name="TagsEntry" Placeholder="z.B. Versand, Lager, Produktion" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource Card}" Padding="18,16">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Druckparameter" Style="{StaticResource SectionTitle}" />

                        <Label Text="BEVORZUGTES MEDIUM" Style="{StaticResource FieldLabel}" />
                        <Label x:Name="PreferredMediaLabel" FontSize="12" TextColor="{DynamicResource ColorText2}" />
                        <Label Text="Wird über den Designer-Button „Medium“ gesetzt." FontSize="11" TextColor="{DynamicResource ColorText3}" Margin="0,2,0,0" />

                        <Label Text="DRUCKGESCHWINDIGKEIT IN IPS (LEER = DRUCKERSTANDARD)" Style="{StaticResource FieldLabel}" />
                        <Entry x:Name="SpeedEntry" Keyboard="Numeric" />

                        <Label Text="DARKNESS 0–30 (LEER = DRUCKERSTANDARD)" Style="{StaticResource FieldLabel}" />
                        <Entry x:Name="DarknessEntry" Keyboard="Numeric" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="Übernehmen" Style="{StaticResource AccentChipButton}" Clicked="OnApplyClicked" HorizontalOptions="Start" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
