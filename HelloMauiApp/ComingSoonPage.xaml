<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelloMauiApp.ComingSoonPage"
             BackgroundColor="{DynamicResource ColorBg}">

    <VerticalStackLayout Padding="40" Spacing="14" VerticalOptions="Center" HorizontalOptions="Center" MaximumWidthRequest="420">
        <Label x:Name="TitleLabel" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" HorizontalTextAlignment="Center" />
        <Label x:Name="MessageLabel" FontSize="14" TextColor="{DynamicResource ColorText2}" HorizontalTextAlignment="Center" />
        <Button x:Name="ActionBtn" Clicked="OnActionClicked" Margin="0,10,0,0"
                BackgroundColor="{DynamicResource ColorControl}" TextColor="{DynamicResource ColorText}" />
    </VerticalStackLayout>

</ContentView>
