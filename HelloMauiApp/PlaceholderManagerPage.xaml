<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HelloMauiApp.PlaceholderManagerPage"
             Title="Platzhalter verwalten"
             BackgroundColor="{DynamicResource ColorBg}">

    <!-- Card/ChipButton/FieldLabel kommen zentral aus Resources/Styles/Styles.xaml -->

    <Grid RowDefinitions="Auto,*" Padding="24,20" RowSpacing="14">

        <!-- KOPFZEILE -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Platzhalter dieser Vorlage" FontSize="22" FontAttributes="Bold" TextColor="{DynamicResource ColorText}" />
                <Label Text="Platzhalter können in Text- und Barcode-Feldern über „Als Platzhalter“ referenziert werden."
                       FontSize="12.5" TextColor="{DynamicResource ColorText2}" />
            </VerticalStackLayout>
            <Button Grid.Column="1" Text="+ Neuer Platzhalter" Style="{StaticResource AccentChipButton}"
                    Clicked="OnAddPlaceholderClicked" VerticalOptions="Center" />
        </Grid>

        <!-- INHALT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" MaximumWidthRequest="860" HorizontalOptions="Fill">

                <VerticalStackLayout x:Name="PlaceholderListLayout" Spacing="8" />

                <Border x:Name="EditPanel" IsVisible="False" Style="{StaticResource Card}" Padding="18,16">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Platzhalter bearbeiten" Style="{StaticResource SectionTitle}" />

                        <Label Text="KEY (EINDEUTIG)" Style="{StaticResource FieldLabel}" />
                        <Entry x:Name="KeyEntry" Placeholder="z.B. sku, empfaenger, versanddatum" />

                        <Label Text="TYP" Style="{StaticResource FieldLabel}" />
                        <Picker x:Name="TypePicker">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Text</x:String>
                                    <x:String>Zahl</x:String>
                                    <x:String>Datum</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>

                        <HorizontalStackLayout Spacing="6" Margin="0,10,0,0">
                            <CheckBox x:Name="RequiredCheckBox" />
                            <Label Text="Pflichtfeld" VerticalOptions="Center" TextColor="{DynamicResource ColorText}" />
                        </HorizontalStackLayout>

                        <Label Text="STANDARDWERT (OPTIONAL)" Style="{StaticResource FieldLabel}" />
                        <Label Text="Wird genutzt, wenn beim Drucken kein Wert geliefert wird."
                               FontSize="11" TextColor="{DynamicResource ColorText3}" />
                        <Entry x:Name="DefaultValueEntry" />

                        <HorizontalStackLayout Spacing="8" Margin="0,16,0,0">
                            <Button Text="Speichern" Style="{StaticResource AccentChipButton}" Clicked="OnSavePlaceholderClicked" />
                            <Button Text="Löschen" Style="{StaticResource DangerButton}" Clicked="OnDeletePlaceholderClicked" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
